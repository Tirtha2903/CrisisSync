# MongoDB Atlas connection string
# Create a free cluster at https://cloud.mongodb.com
MONGO_URI=mongodb+srv://<username>:<password>@<cluster>.mongodb.net/crisissync?retryWrites=true&w=majority

# Secret key for JWT signing — use a long random string in production
JWT_SECRET=change_this_to_a_long_random_secret_string

# Port (Railway sets this automatically)
PORT=5000

# Your deployed Vercel frontend URL (no trailing slash)
CLIENT_URL=https://crisissync.vercel.app
